---
layout: layouts/base.njk
pageTitle: "Forgot Password"
extraCss: auth.css
extraJs: forgot-password.js
---

<div class="auth-page">
  <h1 class="auth-logo">GlossIO</h1>

  <div class="auth-card">
    <p class="auth-tag">Account Recovery</p>
    <h2 class="auth-title">Reset your password</h2>
    <p class="auth-sub">Enter your email address and we'll send you a link to reset your password.</p>

    <form onsubmit="return false">
      <label class="field-label">Email Address</label>
      <input type="email" placeholder="carlos@gmail.com" class="auth-input" id="resetEmail" required>

      <button type="submit" class="auth-btn" id="resetBtn">Send Reset Link</button>
    </form>
  </div>

  <p class="auth-footer">
    Remember your password? <a href="/login/" class="auth-link">Sign In</a>
  </p>
</div>
