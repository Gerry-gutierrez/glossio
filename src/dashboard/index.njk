---
layout: layouts/dashboard.njk
pageTitle: Dashboard
activePage: dashboard
extraCss: dashboard.css
extraJs: dashboard-home.js
---

<!-- Header -->
<div class="dash-header">
  <div>
    <p class="dash-header-label">Welcome back</p>
    <h1 class="dash-header-title">Your Business</h1>
  </div>
  <div class="pending-banner">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FFD60A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
    <span class="pending-text">3 Pending Appointments</span>
  </div>
</div>

<!-- Revenue Stats -->
<div class="stat-grid">
  <div class="stat-card">
    <div class="stat-glow" style="background:radial-gradient(circle,#00E5A010,transparent)"></div>
    <div class="stat-icon" style="background:#00E5A015">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00E5A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
    </div>
    <p class="stat-value" style="color:#00E5A0">$0.00</p>
    <p class="stat-label">Revenue MTD</p>
    <p class="stat-sub">Completed jobs this month</p>
    <p class="stat-detail" style="color:#00E5A0">0 jobs completed</p>
  </div>

  <div class="stat-card">
    <div class="stat-glow" style="background:radial-gradient(circle,#00C2FF10,transparent)"></div>
    <div class="stat-icon" style="background:#00C2FF15">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00C2FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
    </div>
    <p class="stat-value" style="color:#00C2FF">$0.00</p>
    <p class="stat-label">Projected This Month</p>
    <p class="stat-sub">Confirmed + pending remaining</p>
    <p class="stat-detail" style="color:#00C2FF">0 jobs remaining</p>
  </div>

  <div class="stat-card">
    <div class="stat-glow" style="background:radial-gradient(circle,#A259FF10,transparent)"></div>
    <div class="stat-icon" style="background:#A259FF15">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#A259FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    </div>
    <p class="stat-value" style="color:#A259FF">0</p>
    <p class="stat-label">Total Booked</p>
    <p class="stat-sub">All appointments</p>
    <p class="stat-detail" style="color:#A259FF">0 awaiting confirmation</p>
  </div>
</div>

<!-- Appointments -->
<div class="appt-card">
  <div class="appt-header">
    <div>
      <h2 class="appt-title">Appointments</h2>
      <p class="appt-subtitle">0 total</p>
    </div>
    <div class="view-toggle">
      <button class="view-btn view-btn-active">List</button>
      <button class="view-btn view-btn-inactive">Calendar</button>
    </div>
  </div>

  <div class="status-legend">
    <div class="status-item"><div class="status-dot" style="background:#FFD60A"></div><span>Pending (0)</span></div>
    <div class="status-item"><div class="status-dot" style="background:#00C2FF"></div><span>Confirmed (0)</span></div>
    <div class="status-item"><div class="status-dot" style="background:#00E5A0"></div><span>Complete (0)</span></div>
  </div>

  <!-- Recent appointments (populated by JS) -->
  <div id="dash-recent-appts"></div>

  <div class="empty-state">
    <div class="empty-icon" style="background:#00C2FF15">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00C2FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    </div>
    <p class="empty-title">No appointments yet</p>
    <p class="empty-sub">Share your booking link to start getting appointments.</p>
  </div>
</div>

<!-- Quick Actions -->
<div class="quick-actions">
  <h2 class="quick-title">Quick Actions</h2>
  <div class="quick-grid">
    <a href="/dashboard/profile/" class="quick-card">
      <div class="quick-icon" style="background:#00C2FF15">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#00C2FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </div>
      <span class="quick-label">Edit Profile</span>
    </a>
    <a href="/dashboard/services/" class="quick-card">
      <div class="quick-icon" style="background:#A259FF15">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#A259FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
      </div>
      <span class="quick-label">Manage Services</span>
    </a>
    <a href="/dashboard/profile/" class="quick-card">
      <div class="quick-icon" style="background:#FF6B3515">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FF6B35" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      </div>
      <span class="quick-label">Upload Photos</span>
    </a>
    <a href="/dashboard/link/" class="quick-card">
      <div class="quick-icon" style="background:#FFD60A15">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FFD60A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      </div>
      <span class="quick-label">Copy Booking Link</span>
    </a>
  </div>
</div>
