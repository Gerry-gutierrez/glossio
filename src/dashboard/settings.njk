    display: none; align-items: center; justify-content: center; padding: 20px;
  }
  .self-delete-overlay.show { display: flex; }
  .self-delete-modal {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 14px; padding: 32px; max-width: 480px; width: 100%;
    max-height: 90vh; overflow-y: auto;
  }
  .self-delete-icon {
    width: 52px; height: 52px; border-radius: 50%;
    background: rgba(255,51,102,0.15); display: flex; align-items: center; justify-content: center;
    margin: 0 auto 16px;
  }
  .self-delete-modal h3 {
    font-size: 22px; font-weight: 700; color: var(--text);
    margin: 0 0 8px; text-align: center;
  }
  .self-delete-modal p { font-size: 14px; color: var(--text-muted); margin: 0 0 16px; text-align: center; line-height: 1.6; }
  .self-delete-modal strong { color: var(--text); }
  .self-delete-warning {
    background: rgba(255,51,102,0.07); border: 1px solid rgba(255,51,102,0.18);
    border-radius: 10px; padding: 14px 16px; margin-bottom: 20px;
    text-align: left; font-size: 13px; color: var(--text-muted);
  }
  .self-delete-warning strong { color: #FF3366; display: block; margin-bottom: 6px; }
  .self-delete-warning ul { margin: 0; padding-left: 18px; line-height: 1.7; }
  .self-delete-prompt { text-align: left !important; font-size: 13px !important; margin-bottom: 8px !important; }
  .self-delete-input {
    width: 100%; padding: 12px 14px; background: var(--bg-input); border: 1px solid var(--border);
    border-radius: 8px; color: var(--text); font-size: 14px; margin-bottom: 18px;
    font-family: inherit; box-sizing: border-box;
  }
  .self-delete-input:focus { outline: none; border-color: #FF3366; }
  .self-delete-actions { display: flex; gap: 10px; }
  .self-delete-btn {
    flex: 1; padding: 12px; border-radius: 8px; font-size: 14px; font-weight: 600;
    cursor: pointer; transition: opacity 0.15s; border: 1px solid var(--border);
    min-height: 44px;
  }
  .self-delete-cancel { background: transparent; color: var(--text); }
  .self-delete-cancel:hover { background: var(--bg-hover); }
  .self-delete-confirm { background: #FF3366; color: #fff; border-color: #FF3366; }
  .self-delete-confirm:hover:not(:disabled) { opacity: 0.9; }
  .self-delete-confirm:disabled { opacity: 0.4; cursor: not-allowed; }
  .self-delete-error {
    background: rgba(255,51,102,0.1); border: 1px solid rgba(255,51,102,0.3);
    color: #FF3366; border-radius: 8px; padding: 10px 12px;
