<div class="page-header">
  <h1 class="page-title">My Link</h1>
</div>

<!-- Link Card -->
<div class="link-card">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
    <h2 style="font-size:18px;font-weight:700;margin:0">Your Public Profile Link</h2>
  </div>
  <p style="font-size:13px;color:var(--text-dim);margin:0">Share this link anywhere — social media, messages, business cards.</p>

  <div class="link-url-box">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
    <span class="link-url" id="link-url-display">Loading your link...</span>
    <button class="btn btn-primary" style="font-size:12px;padding:8px 16px;white-space:nowrap" id="copyLinkBtn2" onclick="copyProfileLink()">Copy Link</button>
  </div>
</div>

