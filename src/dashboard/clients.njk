---
layout: layouts/dashboard.njk
pageTitle: Clients
activePage: clients
extraCss: dashboard-pages.css
extraJs: clients.js
---

<div class="page-header">
  <h1 class="page-title">Your Clients</h1>
</div>

<!-- Stats -->
<div class="clients-stats">
  <div class="mini-stat" style="border-top:2px solid var(--primary)"><div style="font-size:20px;margin-bottom:8px">👥</div><p class="mini-stat-value" id="stat-total-clients">0</p><p class="mini-stat-label">Total Clients</p></div>
  <div class="mini-stat" style="border-top:2px solid var(--success)"><div style="font-size:20px;margin-bottom:8px">✅</div><p class="mini-stat-value" style="color:#00E5A0" id="stat-came">0</p><p class="mini-stat-label">Came Through</p></div>
  <div class="mini-stat" style="border-top:2px solid var(--gold)"><div style="font-size:20px;margin-bottom:8px">👀</div><p class="mini-stat-value" style="color:#FFD60A" id="stat-never">0</p><p class="mini-stat-label">Never Came</p></div>
  <div class="mini-stat" style="border-top:2px solid var(--secondary)"><div style="font-size:20px;margin-bottom:8px">💰</div><p class="mini-stat-value" style="color:#A259FF" id="stat-revenue">$0.00</p><p class="mini-stat-label">Total Revenue</p></div>
</div>

<!-- Controls -->
<div class="client-controls-bar">
  <div class="search-box">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input id="client-search" type="text" placeholder="Search by name, vehicle, email...">
    <button id="clear-search" class="clear-search" style="display:none" onclick="clearSearch()">✕</button>
  </div>
  <div class="controls-divider"></div>
  <div class="filter-btns">
    <button class="filter-btn filter-btn-active" data-filter="all" onclick="setFilter('all')">All Clients</button>
    <button class="filter-btn" data-filter="active" onclick="setFilter('active')">Came Through ✅</button>
    <button class="filter-btn" data-filter="never_came" onclick="setFilter('never_came')">Never Came 👀</button>
    <button class="filter-btn" data-filter="flaker" onclick="setFilter('flaker')">Flakers ⚠</button>
  </div>
  <div class="controls-divider"></div>
  <div class="sort-control">
    <span class="sort-label">Sort by</span>
    <select id="client-sort" class="sort-select" onchange="setSort(this.value)">
      <option value="recent">Most Recent</option>
      <option value="az">A → Z</option>
      <option value="za">Z → A</option>
      <option value="most_spent">Top Spenders</option>
      <option value="most_visits">Most Visits</option>
    </select>
  </div>
  <span id="result-count" class="result-count"></span>
</div>

<!-- Client List -->
<div id="client-list"></div>

<!-- Empty State -->
<div id="empty-state" class="empty-state" style="padding:80px 20px;display:none">
  <div class="empty-icon" style="background:#A259FF15">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#A259FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
  </div>
  <p class="empty-title">No clients yet</p>
  <p class="empty-sub">When clients book through your link, they'll appear here automatically.</p>
</div>

<!-- No Results -->
<div id="no-results" style="display:none;text-align:center;padding:80px 40px;color:var(--text-faint)">
  <p style="font-size:40px">🔍</p>
  <p style="font-size:16px">No clients match your search.</p>
</div>

<!-- Client Detail View -->
<div id="client-detail" style="display:none"></div>

<!-- Add Client Modal -->
<div id="add-client-modal" class="modal-overlay" style="display:none">
  <div class="modal-box" style="max-width:460px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px">
      <h2 style="margin:0;font-size:20px;font-weight:700">Add Client</h2>
      <button class="modal-close" onclick="closeAddClient()">✕</button>
    </div>
    <div class="form-row">
      <div>
        <p class="field-label">First Name</p>
        <input id="ac-first" class="input" placeholder="e.g. Marcus">
      </div>
      <div>
        <p class="field-label">Last Name</p>
        <input id="ac-last" class="input" placeholder="e.g. T.">
      </div>
    </div>
    <div class="form-row">
      <div>
        <p class="field-label">Phone</p>
        <input id="ac-phone" class="input" placeholder="(239) 555-0101">
      </div>
      <div>
        <p class="field-label">Email</p>
        <input id="ac-email" class="input" placeholder="email@example.com">
      </div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
      <div><p class="field-label">Year</p><input id="ac-vyear" class="input" placeholder="e.g. 2021"></div>
      <div><p class="field-label">Make</p><input id="ac-vmake" class="input" placeholder="e.g. BMW"></div>
      <div><p class="field-label">Model</p><input id="ac-vmodel" class="input" placeholder="e.g. M3"></div>
    </div>
    <p class="field-label">Source</p>
    <select id="ac-source" class="input" style="cursor:pointer">
      <option value="Instagram">Instagram</option>
      <option value="TikTok">TikTok</option>
      <option value="Facebook">Facebook</option>
      <option value="Word of Mouth">Word of Mouth</option>
      <option value="Google">Google</option>
      <option value="Other">Other</option>
    </select>
    <p class="field-label" style="margin-top:16px">Notes</p>
    <textarea id="ac-notes" class="input" style="height:70px;resize:vertical" placeholder="Any notes about this client..."></textarea>
    <div style="display:flex;gap:10px;margin-top:8px">
      <button class="btn btn-ghost" onclick="closeAddClient()">Cancel</button>
      <button class="btn btn-primary" style="flex:1" onclick="addClient()">Add Client</button>
    </div>
    <button class="btn" style="width:100%;margin-top:8px;background:linear-gradient(135deg,rgba(0,194,255,0.12),rgba(162,89,255,0.12));border:1px solid rgba(0,194,255,0.25);color:#00C2FF;font-weight:700;font-size:13px;padding:10px 16px;border-radius:8px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px" onclick="addClientAndSchedule()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="12" y1="14" x2="12" y2="18"/><line x1="10" y1="16" x2="14" y2="16"/></svg>
      Add Client & Schedule Appointment
    </button>
  </div>
</div>
