---
layout: layouts/dashboard.njk
pageTitle: Services
activePage: services
extraCss: dashboard-pages.css
extraJs: services.js
---

<div class="page-header" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px">
  <h1 class="page-title">My Services</h1>
  <div style="display:flex;align-items:center;gap:10px">
    <span id="save-toast" class="save-toast" style="display:none">✓ Changes Saved!</span>
    <button class="btn btn-primary" style="font-size:13px;padding:10px 20px" onclick="openAddModal()">+ Add Service</button>
  </div>
</div>

<div class="services-info">
  <span style="font-size:16px">💡</span>
  These are the services your clients see on your public profile. Keep them updated so clients know exactly what you offer and what it costs.
</div>

<!-- Stats -->
<div class="services-stats">
  <div class="mini-stat" style="border-top:2px solid var(--primary)"><p class="mini-stat-value" id="stat-total">0</p><p class="mini-stat-label">Total Services</p></div>
  <div class="mini-stat" style="border-top:2px solid var(--success)"><p class="mini-stat-value" style="color:#00E5A0" id="stat-min">$0</p><p class="mini-stat-label">Starting From</p></div>
  <div class="mini-stat" style="border-top:2px solid var(--secondary)"><p class="mini-stat-value" style="color:#A259FF" id="stat-max">$0</p><p class="mini-stat-label">Up To</p></div>
</div>

<!-- Service Tabs + Content Container -->
<div id="services-container"></div>

<!-- Products Section -->
<div id="products-section" class="card" style="margin-top:32px">
  <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap">
    <div style="flex:1;min-width:200px">
      <h3 style="font-size:16px;font-weight:700;margin:0;display:flex;align-items:center;gap:8px">
        <span style="font-size:20px">🛒</span> Products
      </h3>
      <p style="font-size:12px;color:var(--text-dim);margin:4px 0 0">Sell sprays, cleaners, merch — anything besides services. Clients see these on your public profile.</p>
    </div>
    <label id="products-toggle-label" style="position:relative;display:inline-block;width:48px;height:26px;cursor:pointer;flex-shrink:0">
      <input type="checkbox" id="products-toggle-input" onchange="toggleProductsEnabled(this.checked)" style="opacity:0;width:0;height:0">
      <span id="products-toggle-track" style="position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0;background:#333;border-radius:26px;transition:.3s"></span>
      <span id="products-toggle-thumb" style="position:absolute;height:20px;width:20px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.3s"></span>
    </label>
  </div>
  <div id="products-container" style="margin-top:20px"></div>
</div>

<!-- Product Add/Edit Modal -->
<div id="product-modal" class="modal-overlay" style="display:none">
  <div class="modal-box" style="max-width:460px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px">
      <h2 id="product-modal-title" style="margin:0;font-size:20px;font-weight:700">Add Product</h2>
      <button class="modal-close" onclick="closeProductModal()">✕</button>
    </div>

    <p class="field-label">Product Photo</p>
    <div id="product-upload-area" style="border:2px dashed var(--border);border-radius:12px;padding:20px;text-align:center;cursor:pointer;margin-bottom:16px" onclick="document.getElementById('product-file-input').click()">
      <input type="file" id="product-file-input" accept="image/*" style="display:none" onchange="handleProductFile(this)">
      <div id="product-upload-placeholder">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--text-faint)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
        <p style="margin:6px 0 0;font-size:13px;color:var(--text-faint)">Click to upload a photo</p>
        <p style="margin:2px 0 0;font-size:11px;color:#444">JPG, PNG, or WebP — max 5 MB</p>
      </div>
      <img id="product-upload-preview" style="display:none;max-width:100%;max-height:200px;border-radius:8px;object-fit:contain" />
    </div>

    <p class="field-label">Product Name *</p>
    <input id="product-name" class="input" placeholder="e.g. SiO2 Ceramic Detailer" maxlength="80">

    <p class="field-label">Price ($) *</p>
    <input id="product-price" class="input" type="number" step="0.01" min="0" placeholder="29.99">

    <p class="field-label">Description</p>
    <textarea id="product-desc" class="input" rows="3" maxlength="300" placeholder="What does this product do? Why should clients buy it?" style="resize:vertical;height:90px"></textarea>

    <div style="display:flex;gap:10px;margin-top:20px">
      <button class="btn btn-ghost" onclick="closeProductModal()">Cancel</button>
      <button id="product-submit-btn" class="btn btn-primary" style="flex:1" onclick="submitProduct()">Add Product</button>
    </div>
  </div>
</div>

<!-- Empty State (shown when no services) -->
<div id="empty-state" class="empty-state" style="padding:80px 20px;display:none">
  <div class="empty-icon" style="background:#A259FF15">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#A259FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
  </div>
  <p class="empty-title">No services yet</p>
  <p class="empty-sub">Add your first service so clients can see what you offer.</p>
  <button class="btn btn-primary" style="font-size:13px;padding:10px 20px;margin-top:12px" onclick="openAddModal()">Add Your First Service</button>
</div>

<!-- Add/Edit Modal -->
<div id="service-modal" class="modal-overlay" style="display:none">
  <div class="modal-box" style="max-width:500px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px">
      <h2 id="modal-title" style="margin:0;font-size:20px;font-weight:700">Add New Service</h2>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>

    <p class="field-label">Choose Icon</p>
    <div id="icon-picker" class="icon-picker"></div>

    <p class="field-label">Accent Color</p>
    <div id="color-picker" class="color-picker"></div>

    <p class="field-label">Service Name</p>
    <input id="svc-name" class="input" placeholder="e.g. Ceramic Coating">

    <p class="field-label">Pricing</p>
    <div id="pricing-toggle" style="display:flex;background:var(--bg);border:1px solid var(--border-light);border-radius:8px;overflow:hidden;margin-bottom:16px">
      <button type="button" id="toggle-fixed" class="pricing-toggle-btn pricing-toggle-active" onclick="setPricingType('fixed')">Set Price</button>
      <button type="button" id="toggle-quote" class="pricing-toggle-btn" onclick="setPricingType('quote')">Request Quote</button>
    </div>
    <div id="price-field-wrap">
      <p class="field-label">Price ($)</p>
      <input id="svc-price" class="input" placeholder="e.g. 199.99">
    </div>

    <!-- Duration (only visible when Time Blocks enabled) -->
    <div id="duration-field-wrap" style="display:none;margin-bottom:16px">
      <p class="field-label">Service Duration</p>
      <select id="svc-duration" class="input">
        <option value="">Not set</option>
        <option value="30">30 minutes</option>
        <option value="45">45 minutes</option>
        <option value="60">1 hour</option>
        <option value="90">1.5 hours</option>
        <option value="120">2 hours</option>
        <option value="150">2.5 hours</option>
        <option value="180">3 hours</option>
        <option value="240">4 hours</option>
        <option value="300">5 hours</option>
        <option value="360">6 hours</option>
        <option value="480">8 hours (full day)</option>
      </select>
      <p style="margin:4px 0 0;font-size:11px;color:var(--text-faint)">How long does this service take? Used to block time slots on your booking page.</p>
    </div>

    <p class="field-label">Description</p>
    <textarea id="svc-desc" class="input" style="height:90px;resize:vertical" placeholder="What's included in this service?"></textarea>

    <!-- Live Preview -->
    <div id="live-preview" class="live-preview" style="display:none">
      <p style="margin:0 0 4px;font-size:10px;color:var(--text-faint);letter-spacing:0.2em;text-transform:uppercase">Preview</p>
      <div style="display:flex;align-items:center;gap:12px">
        <span id="preview-icon" style="font-size:24px"></span>
        <div>
          <p id="preview-name" style="margin:0 0 2px;font-size:14px;font-weight:700"></p>
          <p id="preview-price" style="margin:0;font-size:14px;font-weight:700"></p>
        </div>
      </div>
    </div>

    <div style="display:flex;gap:10px">
      <button class="btn btn-ghost" onclick="closeModal()">Cancel</button>
      <button id="modal-submit" class="btn btn-primary" style="flex:1" onclick="submitService()">Add Service</button>
    </div>
  </div>
</div>

<!-- Delete Confirm Modal -->
<div id="delete-modal" class="modal-overlay" style="display:none">
  <div class="modal-box" style="max-width:380px;text-align:center">
    <p style="font-size:40px;margin-bottom:12px">🗑</p>
    <h3 style="margin:0 0 8px;font-size:18px;font-weight:700">Remove this service?</h3>
    <p style="margin:0 0 28px;font-size:14px;color:var(--text-dim)">Clients will no longer see this on your public profile. This can't be undone.</p>
    <div style="display:flex;gap:10px;justify-content:center">
      <button class="btn btn-danger" onclick="confirmDelete()">Yes, Remove It</button>
      <button class="btn btn-ghost" onclick="closeDeleteModal()">Cancel</button>
    </div>
  </div>
</div>
