---
layout: layouts/dashboard.njk
pageTitle: Appointments
activePage: appointments
extraCss: dashboard-pages.css
extraJs: appointments.js
---

<div class="page-header" style="display:flex;justify-content:space-between;align-items:center">
  <h1 class="page-title">Appointments</h1>
  <button class="btn" id="create-appt-btn" style="background:linear-gradient(135deg,#00C2FF,#A259FF);border:none;border-radius:10px;color:#fff;font-size:13px;font-weight:700;padding:10px 20px;cursor:pointer;display:flex;align-items:center;gap:8px;white-space:nowrap" onclick="openCreateAppt()">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Create Appointment
  </button>
</div>

<!-- Revenue Cards -->
<div class="revenue-cards">
  <div class="stat-card" style="border-top:2px solid var(--success)">
    <div style="font-size:24px;margin-bottom:10px">💰</div>
    <p class="stat-value" style="color:#00E5A0;font-size:28px" id="rev-mtd">$0.00</p>
    <p class="stat-label">Revenue MTD</p>
    <p class="stat-sub" id="rev-mtd-detail">From completed jobs</p>
  </div>
  <div class="stat-card" style="border-top:2px solid var(--primary)">
    <div style="font-size:24px;margin-bottom:10px">📈</div>
    <p class="stat-value" style="color:#00C2FF;font-size:28px" id="rev-projected">$0.00</p>
    <p class="stat-label">Projected This Month</p>
    <p class="stat-sub" id="rev-proj-detail">Confirmed + pending</p>
  </div>
  <div class="stat-card" style="border-top:2px solid var(--secondary)">
    <div style="font-size:24px;margin-bottom:10px">🗓</div>
    <p class="stat-value" style="color:#A259FF;font-size:28px" id="rev-next">$0.00</p>
    <p class="stat-label">Projected Next Month</p>
    <p class="stat-sub" id="rev-next-detail">Upcoming bookings</p>
  </div>
</div>

<!-- Status Grid -->
<div class="status-grid">
  <div class="status-card" onclick="setApptFilter('pending')"><p class="status-card-value" style="color:#FFD60A" id="count-pending">0</p><p class="status-card-label">Awaiting Confirm</p></div>
  <div class="status-card" onclick="setApptFilter('confirmed')"><p class="status-card-value" style="color:#00C2FF" id="count-confirmed">0</p><p class="status-card-label">Confirmed</p></div>
  <div class="status-card" onclick="setApptFilter('complete')"><p class="status-card-value" style="color:#00E5A0" id="count-complete">0</p><p class="status-card-label">Complete</p></div>
  <div class="status-card" onclick="setApptFilter('missed')"><p class="status-card-value" style="color:#FF8C42" id="count-missed">0</p><p class="status-card-label">No-Shows</p></div>
  <div class="status-card" onclick="setApptFilter('cancelled')"><p class="status-card-value" style="color:#FF3366" id="count-cancelled">0</p><p class="status-card-label">Cancelled</p></div>
</div>

<!-- View toggle + heading -->
<div class="appt-toolbar">
  <div>
    <h2 style="margin:0 0 4px;font-size:16px;font-weight:700">Appointments</h2>
    <p id="appt-summary" style="margin:0;font-size:11px;color:var(--text-faint)"></p>
  </div>
  <div class="view-toggle">
    <button class="view-btn view-btn-active" data-view="list" onclick="setApptView('list')">≡ List</button>
    <button class="view-btn" data-view="calendar" onclick="setApptView('calendar')">▦ Calendar</button>
  </div>
</div>

<!-- Search + Filter Tabs -->
<div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;flex-wrap:wrap">
  <div style="position:relative;flex:0 0 220px">
    <span style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text-faint);font-size:13px">🔍</span>
    <input id="appt-search" type="text" placeholder="Search by name, vehicle..." style="width:100%;padding:8px 10px 8px 32px;background:var(--card);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:13px;outline:none" oninput="renderAppts()">
  </div>
  <div class="filter-tabs" id="filter-tabs" style="margin-bottom:0">
    <button class="filter-tab filter-tab-active" data-filter="pending" onclick="setApptFilter('pending')">Pending (0)</button>
    <button class="filter-tab" data-filter="confirmed" onclick="setApptFilter('confirmed')">Confirmed (0)</button>
    <button class="filter-tab" data-filter="complete" onclick="setApptFilter('complete')">Complete (0)</button>
    <button class="filter-tab" data-filter="missed" onclick="setApptFilter('missed')">Missed (0)</button>
    <button class="filter-tab" data-filter="cancelled" onclick="setApptFilter('cancelled')">Cancelled (0)</button>
    <button class="filter-tab" data-filter="all" onclick="setApptFilter('all')">All (0)</button>
  </div>
</div>

<!-- List View -->
<div id="appt-list-view"></div>

<!-- Calendar View -->
<div id="appt-calendar-view" style="display:none"></div>

<!-- Empty State -->
<div id="appt-empty" class="empty-state" style="padding:80px 20px;display:none">
  <div class="empty-icon" style="background:#00C2FF15">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#00C2FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
  </div>
  <p class="empty-title">No appointments yet</p>
  <p class="empty-sub">When clients book through your link, they'll show up here.</p>
</div>

<!-- Create Appointment Modal -->
<div id="create-appt-modal" class="modal-overlay" style="display:none">
  <div class="modal-box" style="max-width:520px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px">
      <h2 id="create-appt-title" style="margin:0;font-size:20px;font-weight:700">Create Appointment</h2>
      <button class="modal-close" onclick="closeCreateAppt()">✕</button>
    </div>

    <!-- Step 1: Choose -->
    <div id="ca-step-choose">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
        <button class="choice-card" onclick="caSetStep('existing')">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
          <span style="font-size:15px;font-weight:700">Existing Client</span>
          <span style="font-size:12px;color:var(--text-dim)">Pick from your client list</span>
        </button>
        <button class="choice-card" onclick="caSetStep('new')">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
          <span style="font-size:15px;font-weight:700">New Client</span>
          <span style="font-size:12px;color:var(--text-dim)">Create a new client</span>
        </button>
      </div>
    </div>

    <!-- Step 2a: Existing client picker -->
    <div id="ca-step-existing" style="display:none">
      <button class="back-link" onclick="caSetStep('choose')">← Back</button>
      <div class="search-box" style="margin-bottom:12px">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input id="ca-client-search" type="text" placeholder="Search clients..." oninput="caFilterClients()">
      </div>
      <div id="ca-client-list" style="max-height:280px;overflow-y:auto;display:flex;flex-direction:column;gap:4px"></div>
    </div>

    <!-- Step 2b: New client form -->
    <div id="ca-step-new" style="display:none">
      <button class="back-link" onclick="caSetStep('choose')">← Back</button>
      <div class="form-row">
        <div><p class="field-label">First Name</p><input id="ca-first" class="input" placeholder="e.g. Marcus"></div>
        <div><p class="field-label">Last Name</p><input id="ca-last" class="input" placeholder="e.g. T."></div>
      </div>
      <div class="form-row">
        <div><p class="field-label">Phone</p><input id="ca-phone" class="input" placeholder="(239) 555-0101"></div>
        <div><p class="field-label">Email</p><input id="ca-email" class="input" placeholder="email@example.com"></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
        <div><p class="field-label">Year</p><input id="ca-vyear" class="input" placeholder="e.g. 2021"></div>
        <div><p class="field-label">Make</p><input id="ca-vmake" class="input" placeholder="e.g. BMW"></div>
        <div><p class="field-label">Model</p><input id="ca-vmodel" class="input" placeholder="e.g. M3"></div>
      </div>
      <p class="field-label" style="margin-top:12px">Source</p>
      <select id="ca-source" class="input" style="cursor:pointer">
        <option value="Instagram">Instagram</option>
        <option value="TikTok">TikTok</option>
        <option value="Facebook">Facebook</option>
        <option value="Word of Mouth">Word of Mouth</option>
        <option value="Google">Google</option>
        <option value="Other">Other</option>
      </select>
    </div>

    <!-- Step 3: Schedule (shown after client selected or for new) -->
    <div id="ca-step-schedule" style="display:none">
      <div id="ca-selected-info" style="margin-bottom:16px"></div>
      <p class="field-label">Service</p>
      <div id="ca-service-grid" class="sched-service-grid"></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px">
        <div><p class="field-label">Date</p><input id="ca-date" type="date" class="input"></div>
        <div><p class="field-label">Time</p><input id="ca-time" type="time" class="input"></div>
      </div>
      <p class="field-label" style="margin-top:16px">Notes (optional)</p>
      <textarea id="ca-notes" class="input" style="height:60px;resize:vertical" placeholder="Any notes..."></textarea>
      <p id="ca-error" style="color:#FF3366;font-size:13px;margin:12px 0 0"></p>
      <div style="display:flex;gap:10px;margin-top:20px">
        <button class="btn btn-ghost" onclick="closeCreateAppt()">Cancel</button>
        <button id="ca-submit-btn" class="btn btn-primary" style="flex:1" onclick="caSubmit()">Schedule Appointment</button>
      </div>
    </div>
  </div>
</div>
