---
layout: layouts/dashboard.njk
pageTitle: Revenue
activePage: revenue
extraCss: dashboard-pages.css
extraJs: revenue.js
---

<div class="page-header">
  <h1 class="page-title">Revenue</h1>
</div>

<!-- Two-column layout -->
<style>.rev-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px}@media(max-width:768px){.rev-grid{grid-template-columns:1fr}}</style>
<div class="rev-grid">

  <!-- LEFT: We Owe -->
  <div class="card" style="padding:24px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
      <h2 style="font-size:16px;font-weight:700;color:#fff;margin:0">We Owe</h2>
      <button onclick="openDebtModal()" style="background:var(--primary);color:#fff;border:none;border-radius:8px;padding:8px 16px;font-size:13px;font-weight:600;cursor:pointer">+ Add</button>
    </div>
    <p style="font-size:12px;color:#555;margin-bottom:16px">Clients who owe you for completed services</p>
    <div id="debts-list"></div>
    <div id="debts-empty" style="display:none;text-align:center;padding:40px 0;color:#444;font-size:13px">
      No outstanding balances
    </div>
  </div>

  <!-- RIGHT: Monthly Revenue -->
  <div class="card" style="padding:24px">
    <h2 style="font-size:16px;font-weight:700;color:#fff;margin:0 0 20px 0">Monthly Revenue</h2>
    <div id="rev-mtd-card" style="background:#0D0D12;border:1.5px solid #1E1E2E;border-radius:12px;padding:20px;margin-bottom:20px">
      <p style="font-size:12px;color:#888;text-transform:uppercase;letter-spacing:1px;margin:0 0 6px 0">This Month</p>
      <p id="rev-mtd-value" style="font-size:32px;font-weight:800;color:#00E5A0;margin:0">$0.00</p>
      <p id="rev-mtd-jobs" style="font-size:12px;color:#555;margin:4px 0 0 0">0 jobs completed</p>
    </div>
    <div id="rev-total-card" style="background:#0D0D12;border:1.5px solid #1E1E2E;border-radius:12px;padding:16px;margin-bottom:20px;display:flex;justify-content:space-between;align-items:center">
      <div>
        <p style="font-size:12px;color:#888;text-transform:uppercase;letter-spacing:1px;margin:0 0 4px 0">All-Time Revenue</p>
        <p id="rev-total-value" style="font-size:22px;font-weight:700;color:#fff;margin:0">$0.00</p>
      </div>
      <div>
        <p style="font-size:12px;color:#888;text-transform:uppercase;letter-spacing:1px;margin:0 0 4px 0">Total Jobs</p>
        <p id="rev-total-jobs" style="font-size:22px;font-weight:700;color:#fff;margin:0;text-align:right">0</p>
      </div>
    </div>
    <h3 style="font-size:13px;font-weight:600;color:#888;margin:0 0 12px 0;text-transform:uppercase;letter-spacing:1px">History</h3>
    <div id="rev-history"></div>
  </div>
</div>

<!-- Debt Modal -->
<div id="debt-modal" class="modal-overlay" style="display:none">
  <div class="modal-card" style="max-width:420px">
    <h3 id="debt-modal-title" style="font-size:16px;font-weight:700;color:#fff;margin:0 0 20px 0">Add Entry</h3>
    <input type="hidden" id="debt-edit-id">
    <div style="margin-bottom:14px">
      <label style="font-size:12px;color:#888;display:block;margin-bottom:4px">First Name *</label>
      <input id="debt-first" type="text" placeholder="First name" style="width:100%;padding:10px 14px;background:#0D0D12;border:1.5px solid #1E1E2E;border-radius:8px;color:#fff;font-size:14px;box-sizing:border-box">
    </div>
    <div style="margin-bottom:14px">
      <label style="font-size:12px;color:#888;display:block;margin-bottom:4px">Last Name</label>
      <input id="debt-last" type="text" placeholder="Last name" style="width:100%;padding:10px 14px;background:#0D0D12;border:1.5px solid #1E1E2E;border-radius:8px;color:#fff;font-size:14px;box-sizing:border-box">
    </div>
    <div style="margin-bottom:14px">
      <label style="font-size:12px;color:#888;display:block;margin-bottom:4px">Phone</label>
      <input id="debt-phone" type="tel" placeholder="(239) 555-1234" style="width:100%;padding:10px 14px;background:#0D0D12;border:1.5px solid #1E1E2E;border-radius:8px;color:#fff;font-size:14px;box-sizing:border-box">
    </div>
    <div style="margin-bottom:14px">
      <label style="font-size:12px;color:#888;display:block;margin-bottom:4px">Amount Owed *</label>
      <input id="debt-amount" type="number" step="0.01" min="0" placeholder="0.00" style="width:100%;padding:10px 14px;background:#0D0D12;border:1.5px solid #1E1E2E;border-radius:8px;color:#fff;font-size:14px;box-sizing:border-box">
    </div>
    <div style="margin-bottom:20px">
      <label style="font-size:12px;color:#888;display:block;margin-bottom:4px">Notes (optional)</label>
      <input id="debt-notes" type="text" placeholder="e.g. Waiting on check" style="width:100%;padding:10px 14px;background:#0D0D12;border:1.5px solid #1E1E2E;border-radius:8px;color:#fff;font-size:14px;box-sizing:border-box">
    </div>
    <div style="display:flex;gap:10px;justify-content:flex-end">
      <button onclick="closeDebtModal()" style="padding:10px 20px;background:transparent;border:1.5px solid #1E1E2E;border-radius:8px;color:#888;font-size:13px;cursor:pointer">Cancel</button>
      <button onclick="submitDebt()" style="padding:10px 20px;background:var(--primary);border:none;border-radius:8px;color:#fff;font-size:13px;font-weight:600;cursor:pointer">Save</button>
    </div>
  </div>
</div>

<div style="height:100px"></div>
