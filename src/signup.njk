---
layout: layouts/base.njk
pageTitle: "Start Free Trial"
extraCss: auth.css
extraJs: signup.js
---

<div class="auth-page">
  <h1 class="auth-logo">GlossIO</h1>

  <!-- Progress Bar -->
  <div class="progress-bar" id="progressBar">
    <div class="progress-steps">
      <div class="progress-step">
        <div class="progress-dot progress-dot-current" id="dot1">1</div>
        <span class="progress-step-label" style="color:#888">Your Info</span>
      </div>
      <div class="progress-step">
        <div class="progress-dot progress-dot-pending" id="dot2">2</div>
        <span class="progress-step-label" style="color:#444">Create Login</span>
      </div>
      <div class="progress-step">
        <div class="progress-dot progress-dot-pending" id="dot3">3</div>
        <span class="progress-step-label" style="color:#444">Verify Phone</span>
      </div>
    </div>
    <div class="progress-track">
      <div class="progress-fill" id="progressFill" style="width:0%"></div>
    </div>
  </div>

  <!-- Card -->
  <div class="auth-card" style="max-width:520px">
    <div class="auth-error" id="signupError" style="display:none"></div>

    <!-- STEP 1 -->
    <div id="step1">
      <p class="auth-tag">Step 1 of 2</p>
      <h2 class="auth-title">Let's get you set up</h2>
      <p class="auth-sub">Tell us a bit about yourself. You can add your business phone and address later in your profile.</p>

      <label class="field-label">Company Name <span class="optional-label">(optional)</span></label>
      <input type="text" placeholder="e.g. Carlos Detail Co." class="auth-input" id="companyName">

      <div class="form-grid">
        <div>
          <label class="field-label">First Name</label>
          <input type="text" placeholder="Carlos" class="auth-input" id="firstName">
        </div>
        <div>
          <label class="field-label">Last Name</label>
          <input type="text" placeholder="Martinez" class="auth-input" id="lastName">
        </div>
      </div>

      <label class="field-label">Cell Phone Number</label>
      <input type="tel" placeholder="(239) 555-0100" class="auth-input" id="cellPhone">
      <p class="field-hint">Double-check your number — we'll text you a verification code</p>

      <label class="field-label">Email Address</label>
      <input type="email" placeholder="carlos@gmail.com" class="auth-input" id="signupEmail">

      <label class="field-label">Address <span class="optional-label">(optional)</span></label>
      <input type="text" placeholder="123 Main St, Naples, FL 34102" class="auth-input" id="address">

      <div class="info-box">
        <p>No credit card needed. Try GlossIO free for 14 days.</p>
      </div>

      <button type="button" class="auth-btn auth-btn-gradient" id="step1Btn" onclick="goToStep(2)">Continue →</button>
    </div>

    <!-- STEP 2 -->
    <div id="step2" style="display:none">
      <p class="auth-tag">Step 2 of 2</p>
      <h2 class="auth-title">Create your password</h2>
      <p class="auth-sub">You'll sign in with your email and this password.</p>

      <label class="field-label">Password</label>
      <div class="password-wrap">
        <input type="password" placeholder="Min. 8 characters" class="auth-input" id="signupPassword">
        <button type="button" class="password-toggle" onclick="togglePassword('signupPassword')">&#128065;</button>
      </div>

      <label class="field-label">Confirm Password</label>
      <div class="password-wrap">
        <input type="password" placeholder="Re-enter password" class="auth-input" id="confirmPassword">
        <button type="button" class="password-toggle" onclick="togglePassword('confirmPassword')">&#128065;</button>
      </div>

      <div id="mismatchMsg" style="display:none;margin:0 0 12px;font-size:12px;color:#FF3366">Passwords don't match</div>

      <div id="strengthBar" style="display:none">
        <div class="strength-bar">
          <div class="strength-fill" id="strengthFill"></div>
        </div>
        <p class="strength-label" id="strengthLabel"></p>
      </div>

      <div class="btn-row">
        <button type="button" class="ghost-btn" onclick="goToStep(1)">&larr; Back</button>
        <button type="button" class="auth-btn auth-btn-gradient" id="step2Btn" onclick="goToStep(3)">Continue →</button>
      </div>
    </div>

    <!-- STEP 3: SMS Verification -->
    <div id="step3" style="display:none">
      <p class="auth-tag">Step 3 of 3</p>
      <h2 class="auth-title">Verify your phone</h2>
      <p class="auth-sub">We sent a 6-digit code to <strong id="verifyPhoneDisplay">your phone</strong></p>

      <div class="otp-row" id="otpRow">
        <input type="text" inputmode="numeric" maxlength="1" class="otp-input" data-otp="0" autocomplete="one-time-code">
        <input type="text" inputmode="numeric" maxlength="1" class="otp-input" data-otp="1">
        <input type="text" inputmode="numeric" maxlength="1" class="otp-input" data-otp="2">
        <input type="text" inputmode="numeric" maxlength="1" class="otp-input" data-otp="3">
        <input type="text" inputmode="numeric" maxlength="1" class="otp-input" data-otp="4">
        <input type="text" inputmode="numeric" maxlength="1" class="otp-input" data-otp="5">
      </div>

      <div id="verifyStatus" class="verify-status"></div>

      <button type="button" class="auth-btn auth-btn-gradient" id="verifyBtn" onclick="submitVerification()" disabled>Verify &amp; Create Account</button>

      <div class="verify-help">
        <p class="verify-help-title">Never received the code?</p>
        <div class="verify-help-actions">
          <button type="button" class="verify-link" id="resendBtn" onclick="resendCode()">Resend Code</button>
          <span class="verify-divider">·</span>
          <button type="button" class="verify-link" onclick="changePhoneNumber()">Change Number</button>
        </div>
        <p class="verify-help-support" id="verifySupportNote" style="display:none">
          Still nothing? Email <a href="mailto:support@glossio.app" class="auth-link">support@glossio.app</a>
        </p>
      </div>
    </div>

    <!-- STEP 4: Success -->
    <div id="step4" style="display:none;text-align:center;padding:20px 0">
      <div class="success-circle">&#10003;</div>
      <h2 class="auth-title" style="text-align:center" id="welcomeTitle">You're in!</h2>
      <p class="auth-sub" style="text-align:center">Your 14-day free trial has started. Head to your dashboard to set up your profile, add your services, and grab your booking link.</p>

      <div class="checklist">
        <div class="checklist-item"><span class="checklist-icon">&#127912;</span><span class="checklist-text">Customize your public profile</span></div>
        <div class="checklist-item"><span class="checklist-icon">&#128736;</span><span class="checklist-text">Add your services &amp; prices</span></div>
        <div class="checklist-item"><span class="checklist-icon">&#128279;</span><span class="checklist-text">Copy &amp; share your booking link</span></div>
        <div class="checklist-item"><span class="checklist-icon">&#128197;</span><span class="checklist-text">Watch appointments roll in</span></div>
      </div>

      <a href="/dashboard/" class="auth-btn auth-btn-gradient" style="display:block;text-decoration:none;text-align:center">Go to My Dashboard →</a>
    </div>
  </div>

  <p class="auth-footer" id="signupFooter">
    Already have an account? <a href="/login/" class="auth-link">Sign In</a>
  </p>
</div>
