---
layout: layouts/base.njk
pageTitle: "Admin Dashboard"
---

<style>
  .admin-wrap { max-width: 1000px; margin: 0 auto; padding: 40px 20px; }
  .admin-title { font-size: 28px; font-weight: 700; color: var(--text); margin-bottom: 8px; }
  .admin-subtitle { font-size: 14px; color: var(--text-muted); margin-bottom: 32px; }

  /* Login gate */
  .admin-login-box {
    max-width: 380px; margin: 120px auto; padding: 40px;
    background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-md);
    text-align: center;
  }
  .admin-login-box h2 { font-size: 22px; font-weight: 700; color: var(--text); margin-bottom: 8px; }
  .admin-login-box p { font-size: 13px; color: var(--text-muted); margin-bottom: 24px; }
  .admin-login-box input {
    width: 100%; padding: 12px 16px; background: var(--bg-input); border: 1px solid var(--border);
    border-radius: var(--radius-sm); color: var(--text); font-size: 14px; margin-bottom: 16px;
  }
  .admin-login-box input:focus { outline: none; border-color: var(--primary); }
  .pass-toggle {
    position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
    background: none; border: none; color: var(--text-muted); cursor: pointer; padding: 4px;
  }
  .pass-toggle:hover { color: var(--text); }
  .admin-login-btn {
    width: 100%; padding: 12px; background: var(--primary); color: #fff; border: none;
    border-radius: var(--radius-sm); font-size: 14px; font-weight: 600; cursor: pointer;
    transition: opacity 0.2s;
  }
  .admin-login-btn:hover { opacity: 0.85; }
  .admin-error { color: var(--danger); font-size: 13px; margin-top: 12px; display: none; }

  /* Stats bar */
  .admin-stats { display: flex; gap: 16px; margin-bottom: 32px; flex-wrap: wrap; }
  .stat-card {
    flex: 1; min-width: 140px; padding: 20px; background: var(--bg-card);
    border: 1px solid var(--border); border-radius: var(--radius-md); text-align: center;
  }
  .stat-number { font-size: 32px; font-weight: 700; }
  .stat-number.active { color: var(--success); }
  .stat-number.paused { color: var(--text-muted); }
  .stat-number.total { color: var(--primary); }
  .stat-label { font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }

  /* Tabs */
  .admin-tabs { display: flex; gap: 0; margin-bottom: 24px; border-bottom: 1px solid var(--border); }
  .admin-tab {
    padding: 12px 24px; font-size: 14px; font-weight: 600; color: var(--text-muted);
    cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.2s;
    background: none; border-top: none; border-left: none; border-right: none;
  }
  .admin-tab:hover { color: var(--text); }
  .admin-tab.active { color: var(--primary); border-bottom-color: var(--primary); }

  /* Table */
  .admin-table { width: 100%; border-collapse: collapse; }
  .admin-table th {
    text-align: left; padding: 12px 16px; font-size: 11px; font-weight: 600;
    color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px;
    border-bottom: 1px solid var(--border);
  }
  .admin-table td {
    padding: 14px 16px; font-size: 14px; color: var(--text);
    border-bottom: 1px solid var(--border);
  }
  .admin-table tr:hover td { background: var(--bg-hover); }

  /* Status badges */
  .badge {
    display: inline-block; padding: 4px 10px; border-radius: 20px;
    font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;
  }
  .badge-trial { background: rgba(0,194,255,0.15); color: var(--primary); }
  .badge-monthly { background: rgba(162,89,255,0.15); color: var(--secondary); }
  .badge-annual { background: rgba(0,229,160,0.15); color: var(--success); }
  .badge-cancelled { background: rgba(255,51,102,0.15); color: var(--danger); }
  .badge-expired { background: rgba(136,136,136,0.15); color: var(--text-muted); }

  .admin-empty { text-align: center; padding: 60px 20px; color: var(--text-muted); font-size: 14px; }
  .admin-loading { text-align: center; padding: 60px 20px; color: var(--text-muted); font-size: 14px; }

  /* Delete button */
  .delete-btn {
    background: rgba(255,51,102,0.12); color: var(--danger);
    border: 1px solid rgba(255,51,102,0.3); border-radius: 6px;
    padding: 6px 12px; font-size: 12px; font-weight: 600; cursor: pointer;
    transition: all 0.15s;
  }
  .delete-btn:hover { background: var(--danger); color: #fff; border-color: var(--danger); }
  .delete-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* Delete confirmation modal */
  .delete-modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 200;
    display: none; align-items: center; justify-content: center; padding: 20px;
  }
  .delete-modal-overlay.show { display: flex; }
  .delete-modal {
    background: var(--bg-card); border: 1px solid var(--border);
    border-radius: 12px; padding: 32px; max-width: 460px; width: 100%;
  }
  .delete-modal-icon {
    width: 48px; height: 48px; border-radius: 50%;
    background: rgba(255,51,102,0.15); display: flex; align-items: center; justify-content: center;
    margin: 0 auto 16px;
  }
  .delete-modal h3 { font-size: 20px; font-weight: 700; color: var(--text); margin: 0 0 8px; text-align: center; }
  .delete-modal p { font-size: 14px; color: var(--text-muted); margin: 0 0 20px; text-align: center; line-height: 1.6; }
  .delete-modal strong { color: var(--text); }
  .delete-modal-warning {
    background: rgba(255,51,102,0.08); border: 1px solid rgba(255,51,102,0.2);
    border-radius: 8px; padding: 12px 14px; font-size: 13px; color: var(--text-muted);
    margin-bottom: 20px; line-height: 1.5;
  }
  .delete-modal-input {
    width: 100%; padding: 12px 14px; background: var(--bg-input); border: 1px solid var(--border);
    border-radius: 8px; color: var(--text); font-size: 14px; margin-bottom: 16px;
    font-family: inherit;
  }
  .delete-modal-input:focus { outline: none; border-color: var(--danger); }
  .delete-modal-actions { display: flex; gap: 10px; }
  .delete-modal-btn {
    flex: 1; padding: 11px; border-radius: 8px; font-size: 14px; font-weight: 600;
    cursor: pointer; transition: opacity 0.15s; border: 1px solid var(--border);
  }
  .delete-modal-cancel { background: transparent; color: var(--text); }
  .delete-modal-cancel:hover { background: var(--bg-hover); }
  .delete-modal-confirm {
    background: var(--danger); color: #fff; border-color: var(--danger);
  }
  .delete-modal-confirm:hover:not(:disabled) { opacity: 0.9; }
  .delete-modal-confirm:disabled { opacity: 0.4; cursor: not-allowed; }
  .delete-modal-error {
    background: rgba(255,51,102,0.1); border: 1px solid rgba(255,51,102,0.3);
    color: var(--danger); border-radius: 8px; padding: 10px 12px;
    font-size: 13px; margin-top: 12px; display: none;
  }
  .delete-modal-error.show { display: block; }

  /* Sign out link */
  .admin-signout {
    font-size: 13px; color: var(--text-muted); cursor: pointer;
    background: none; border: none; float: right; margin-top: -48px;
  }
  .admin-signout:hover { color: var(--danger); }

  @media (max-width: 600px) {
    .admin-stats { flex-direction: column; }
    .admin-table th:nth-child(3), .admin-table td:nth-child(3),
    .admin-table th:nth-child(5), .admin-table td:nth-child(5) { display: none; }
  }
</style>

<!-- LOGIN GATE -->
<div id="adminLogin" class="admin-login-box">
  <h2>Admin Access</h2>
  <p>Enter the admin password to continue.</p>
  <div style="position:relative">
    <input type="password" id="adminPass" placeholder="Password" autocomplete="off">
    <button type="button" class="pass-toggle" onclick="togglePassVis()" aria-label="Show password">
      <svg id="eyeIcon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
    </button>
  </div>
  <button class="admin-login-btn" onclick="adminAuth()">Enter</button>
  <div class="admin-error" id="adminError">Incorrect password</div>
</div>

<!-- DASHBOARD (hidden until auth) -->
<div id="adminDash" style="display:none">
  <div class="admin-wrap">
    <h1 class="admin-title">Admin Dashboard</h1>
    <p class="admin-subtitle">GlossIO platform overview</p>
    <button class="admin-signout" onclick="adminSignOut()">Sign Out</button>

    <div class="admin-stats">
      <div class="stat-card">
        <div class="stat-number total" id="statTotal">—</div>
        <div class="stat-label">Total Users</div>
      </div>
      <div class="stat-card">
        <div class="stat-number active" id="statActive">—</div>
        <div class="stat-label">Active</div>
      </div>
      <div class="stat-card">
        <div class="stat-number paused" id="statPaused">—</div>
        <div class="stat-label">Paused</div>
      </div>
    </div>

    <div class="admin-tabs">
      <button class="admin-tab active" data-filter="all" onclick="filterTab(this)">All Users</button>
      <button class="admin-tab" data-filter="active" onclick="filterTab(this)">Active</button>
      <button class="admin-tab" data-filter="paused" onclick="filterTab(this)">Paused</button>
    </div>

    <div id="adminTableWrap">
      <div class="admin-loading">Loading users...</div>
    </div>
  </div>
</div>

<!-- DELETE CONFIRMATION MODAL -->
<div id="deleteModal" class="delete-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle">
  <div class="delete-modal">
    <div class="delete-modal-icon">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#FF3366" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"/>
      </svg>
    </div>
    <h3 id="deleteModalTitle">Delete user?</h3>
    <p>You are about to permanently delete <strong id="deleteUserName">this user</strong>. This action cannot be undone.</p>

    <div class="delete-modal-warning">
      <strong>This will also:</strong><br>
      • Cancel any active Stripe subscription immediately<br>
      • Delete all their services, clients, appointments, photos, and history
    </div>

    <p style="text-align:left;font-size:13px;margin-bottom:8px">Type <strong>DELETE</strong> to confirm:</p>
    <input type="text" id="deleteConfirmInput" class="delete-modal-input" placeholder="DELETE" autocomplete="off">

    <div class="delete-modal-actions">
      <button class="delete-modal-btn delete-modal-cancel" onclick="closeDeleteModal()">Cancel</button>
      <button class="delete-modal-btn delete-modal-confirm" id="deleteConfirmBtn" onclick="confirmDelete()" disabled>Delete Permanently</button>
    </div>
    <div class="delete-modal-error" id="deleteModalError"></div>
  </div>
</div>

<script>
(function () {
  var ADMIN_PASS_HASH = null; // We'll use a simple check via env
  var users = [];
  var currentFilter = 'all';
  var pendingDeleteUser = null; // { id, label }

  /* ── Auth ── */
  function adminAuth() {
    var pass = document.getElementById('adminPass').value;
    // Call the admin-auth function to verify
    fetch('/.netlify/functions/admin-users?action=auth&pass=' + encodeURIComponent(pass))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.ok) {
          sessionStorage.setItem('glossio_admin', '1');
          sessionStorage.setItem('glossio_admin_pass', pass);
          showDashboard();
        } else {
          document.getElementById('adminError').style.display = 'block';
        }
      })
      .catch(function() {
        document.getElementById('adminError').style.display = 'block';
      });
  }
  window.adminAuth = adminAuth;

  function togglePassVis() {
    var inp = document.getElementById('adminPass');
    var isHidden = inp.type === 'password';
    inp.type = isHidden ? 'text' : 'password';
    document.getElementById('eyeIcon').innerHTML = isHidden
      ? '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>'
      : '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
  }
  window.togglePassVis = togglePassVis;

  document.getElementById('adminPass').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') adminAuth();
  });

  function adminSignOut() {
    sessionStorage.removeItem('glossio_admin');
    sessionStorage.removeItem('glossio_admin_pass');
    document.getElementById('adminDash').style.display = 'none';
    document.getElementById('adminLogin').style.display = 'block';
    document.getElementById('adminPass').value = '';
  }
  window.adminSignOut = adminSignOut;

  /* ── Show dashboard ── */
  function showDashboard() {
    document.getElementById('adminLogin').style.display = 'none';
    document.getElementById('adminDash').style.display = 'block';
    loadUsers();
  }

  /* ── Load users ── */
  function loadUsers() {
    var pass = sessionStorage.getItem('glossio_admin_pass') || '';
    fetch('/.netlify/functions/admin-users?pass=' + encodeURIComponent(pass))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error) {
          document.getElementById('adminTableWrap').innerHTML =
            '<div class="admin-empty">Access denied</div>';
          return;
        }
        users = data.users || [];
        updateStats();
        renderTable();
      })
      .catch(function() {
        document.getElementById('adminTableWrap').innerHTML =
          '<div class="admin-empty">Failed to load users</div>';
      });
  }

  /* ── Stats ── */
  function updateStats() {
    var active = 0, paused = 0;
    users.forEach(function(u) {
      if (u.status === 'active') active++;
      else paused++;
    });
    document.getElementById('statTotal').textContent = users.length;
    document.getElementById('statActive').textContent = active;
    document.getElementById('statPaused').textContent = paused;
  }

  /* ── Filter tabs ── */
  function filterTab(btn) {
    document.querySelectorAll('.admin-tab').forEach(function(t) { t.classList.remove('active'); });
    btn.classList.add('active');
    currentFilter = btn.getAttribute('data-filter');
    renderTable();
  }
  window.filterTab = filterTab;

  /* ── Render ── */
  function renderTable() {
    var filtered = users;
    if (currentFilter === 'active') filtered = users.filter(function(u) { return u.status === 'active'; });
    if (currentFilter === 'paused') filtered = users.filter(function(u) { return u.status !== 'active'; });

    if (filtered.length === 0) {
      document.getElementById('adminTableWrap').innerHTML =
        '<div class="admin-empty">No users found</div>';
      return;
    }

    var html = '<table class="admin-table"><thead><tr>' +
      '<th>Business</th><th>Email</th><th>Phone</th><th>Status</th><th>Plan</th><th>Signed Up</th><th></th>' +
      '</tr></thead><tbody>';

    filtered.forEach(function(u) {
      var badgeClass = 'badge-' + (u.plan || 'expired').toLowerCase().replace(' ', '');
      if (badgeClass === 'badge-freetrial') badgeClass = 'badge-trial';
      var dateStr = u.created_at ? new Date(u.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—';
      var statusDot = u.status === 'active'
        ? '<span style="color:var(--success)">● Active</span>'
        : '<span style="color:var(--text-muted)">● Paused</span>';

      var safeLabel = (u.company_name || u.email || 'this user').replace(/'/g, "\\'");
      html += '<tr>' +
        '<td>' + (u.company_name || '—') + '</td>' +
        '<td style="color:var(--text-muted)">' + (u.email || '—') + '</td>' +
        '<td style="color:var(--text-muted)">' + (u.phone || '—') + '</td>' +
        '<td>' + statusDot + '</td>' +
        '<td><span class="badge ' + badgeClass + '">' + (u.plan || 'Expired') + '</span></td>' +
        '<td style="color:var(--text-muted)">' + dateStr + '</td>' +
        '<td style="text-align:right">' +
          '<button class="delete-btn" onclick="openDeleteModal(\'' + u.id + '\', \'' + safeLabel + '\')">Delete</button>' +
        '</td>' +
        '</tr>';
    });

    html += '</tbody></table>';
    document.getElementById('adminTableWrap').innerHTML = html;
  }

  /* ── Delete user flow ── */
  function openDeleteModal(userId, label) {
    pendingDeleteUser = { id: userId, label: label };
    document.getElementById('deleteUserName').textContent = label;
    document.getElementById('deleteConfirmInput').value = '';
    document.getElementById('deleteConfirmBtn').disabled = true;
    document.getElementById('deleteConfirmBtn').textContent = 'Delete Permanently';
    document.getElementById('deleteModalError').classList.remove('show');
    document.getElementById('deleteModal').classList.add('show');
    setTimeout(function() { document.getElementById('deleteConfirmInput').focus(); }, 50);
  }
  window.openDeleteModal = openDeleteModal;

  function closeDeleteModal() {
    document.getElementById('deleteModal').classList.remove('show');
    pendingDeleteUser = null;
  }
  window.closeDeleteModal = closeDeleteModal;

  /* Enable confirm button only when input matches "DELETE" */
  document.getElementById('deleteConfirmInput').addEventListener('input', function(e) {
    var btn = document.getElementById('deleteConfirmBtn');
    btn.disabled = e.target.value.trim() !== 'DELETE';
  });

  /* ESC closes modal */
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && document.getElementById('deleteModal').classList.contains('show')) {
      closeDeleteModal();
    }
  });

  /* Click outside modal closes it */
  document.getElementById('deleteModal').addEventListener('click', function(e) {
    if (e.target.id === 'deleteModal') closeDeleteModal();
  });

  function confirmDelete() {
    if (!pendingDeleteUser) return;
    var btn = document.getElementById('deleteConfirmBtn');
    var errEl = document.getElementById('deleteModalError');
    btn.disabled = true;
    btn.textContent = 'Deleting...';
    errEl.classList.remove('show');

    var pass = sessionStorage.getItem('glossio_admin_pass') || '';

    fetch('/.netlify/functions/admin-delete-user', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId: pendingDeleteUser.id, pass: pass }),
    })
      .then(function(r) { return r.json().then(function(d) { return { status: r.status, data: d }; }); })
      .then(function(res) {
        if (res.status === 200 && res.data.ok) {
          closeDeleteModal();
          loadUsers(); // refresh table
        } else {
          errEl.textContent = res.data.error || 'Failed to delete user. Please try again.';
          errEl.classList.add('show');
          btn.disabled = false;
          btn.textContent = 'Delete Permanently';
        }
      })
      .catch(function(err) {
        errEl.textContent = 'Network error. Please try again.';
        errEl.classList.add('show');
        btn.disabled = false;
        btn.textContent = 'Delete Permanently';
      });
  }
  window.confirmDelete = confirmDelete;

  /* Auto-login if session exists */
  if (sessionStorage.getItem('glossio_admin') === '1') {
    showDashboard();
  }
})();
</script>
