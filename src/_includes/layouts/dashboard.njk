<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>{{ pageTitle }} — GlossIO Dashboard</title>
  <link rel="stylesheet" href="/css/globals.css">
  <link rel="stylesheet" href="/css/dashboard-layout.css">
  {% if extraCss %}<link rel="stylesheet" href="/css/{{ extraCss }}">{% endif %}
</head>
<body>
  <div class="shell">
    <!-- Hamburger (mobile) -->
    <button class="hamburger" id="hamburgerBtn" aria-label="Toggle menu">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <!-- Mobile overlay -->
    <div class="overlay" id="sidebarOverlay"></div>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <p class="sidebar-label">Platform</p>
        <a href="/" class="gradient-text" style="font-size:22px;font-weight:700;display:block">GlossIO</a>
      </div>

      <!-- User card -->
      <div class="user-card">
        <div class="user-avatar">Y</div>
        <div style="overflow:hidden">
          <p class="user-name">Your Business</p>
          <p class="user-plan">Free Trial</p>
        </div>
      </div>

      <!-- Nav -->
      <nav class="dash-nav">
        <a href="/dashboard/" class="nav-btn {{ 'nav-btn-active' if activePage == 'dashboard' }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect></svg>
          Dashboard
        </a>
        <a href="/dashboard/appointments/" class="nav-btn {{ 'nav-btn-active' if activePage == 'appointments' }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          Appointments
        </a>
        <a href="/dashboard/clients/" class="nav-btn {{ 'nav-btn-active' if activePage == 'clients' }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          Clients
        </a>
        <a href="/dashboard/services/" class="nav-btn {{ 'nav-btn-active' if activePage == 'services' }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
          Services
        </a>
        <a href="/dashboard/profile/" class="nav-btn {{ 'nav-btn-active' if activePage == 'profile' }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          My Profile
        </a>
        <a href="/dashboard/link/" class="nav-btn {{ 'nav-btn-active' if activePage == 'link' }}">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
          My Link
        </a>
        <a href="/dashboard/settings/" class="nav-btn {{ 'nav-btn-active' if activePage == 'settings' }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line></svg>
          Settings
        </a>
      </nav>

      <!-- Footer -->
      <div class="sidebar-footer">
        <a href="/login/" class="sign-out-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
          </svg>
          Sign Out
        </a>
      </div>
    </aside>

    <!-- Main content -->
    <main class="main-content">
      {{ content | safe }}
    </main>
  </div>

  <!-- Supabase SDK (CDN) -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>

  <!-- Runtime config (injected by server.js from env vars) -->
  <script src="/config.js"></script>

  <script src="/js/supabase-client.js"></script>
  <script src="/js/supabase-data.js"></script>
  <script src="/js/api.js"></script>
  <script src="/js/auth-guard.js"></script>
  <script src="/js/sentry-init.js"></script>

  <script src="/js/dashboard.js"></script>
  {% if extraJs %}<script src="/js/{{ extraJs }}"></script>{% endif %}
</body>
</html>
