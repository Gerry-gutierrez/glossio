<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>{{ pageTitle or site.title }} — {{ site.title }}</title>
  <meta name="description" content="{{ pageDescription or site.description }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ ogTitle or pageTitle or site.title }}">
  <meta property="og:description" content="{{ ogDescription or pageDescription or site.description }}">
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:site_name" content="GlossIO">
  <meta property="og:url" content="https://www.glossio.org">
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ ogTitle or pageTitle or site.title }}">
  <meta name="twitter:description" content="{{ ogDescription or pageDescription or site.description }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/globals.css">
  {% if extraCss %}<link rel="stylesheet" href="/css/{{ extraCss }}">{% endif %}
</head>
<body>
  {{ content | safe }}

  <!-- Supabase SDK (CDN) -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>

  <!-- Runtime config (injected by server.js from env vars) -->
  <script src="/config.js"></script>

  <!-- Core scripts -->
  <script src="/js/supabase-client.js"></script>
  <script src="/js/supabase-data.js"></script>
  <script src="/js/api.js"></script>
  <script src="/js/sentry-init.js"></script>

  {% if extraJs %}<script src="/js/{{ extraJs }}"></script>{% endif %}
</body>
</html>
